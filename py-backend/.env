# Database Configuration
# Format: postgresql://user:password@host:port/database_name
# Replace with your actual PostgreSQL connection string
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:5432/naturabotanica

# Email Configuration (Brevo / SMTP)
# Replace 'your_actual_brevo_password_here' with your real Brevo password.
# Do NOT use 'YOUR_BREVO_PASSWORD_GOES_HERE' as a string.
EMAIL_USER=a9f3cc001@smtp-brevo.com
EMAIL_PASS=your_actual_brevo_password_here

# API Security
# Generate a random secure string and use it here for checking the API secret.
API_SECRET=super_secret_random_password_123

# Inventory API (Optional)
# Only needed if you are using the check_inventory_api feature.
INVENTORY_API_URL=https://api.your-inventory-provider.com/v1

# Flask Debug Mode
# Set to "1" (true) if you want the background worker to run ONLY locally (helps for testing).
# Set to "0" (false) for Production (on Render).
FLASK_DEBUG=0
