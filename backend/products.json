  // NEW: AMRIT DHARA ADDED HERE
  { id: 58, name: "Amrit Dhara", sci: "Traditional Ayurvedic Blend", category: "oils", catLabel: "Oils", price:100, unit: "15 ml", moq: "15 ml", lead: "7-10 days", img: "images/amrit-dhara.jpg", desc: "A potent traditional essential oil blend often used for relief from stomach aches, headaches, and common colds. Distilled from a mixture of camphor, ajwain, and nilgiri. A staple in Nepalese households." },
