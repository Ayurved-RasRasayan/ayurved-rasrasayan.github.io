  // ── Rasa Uparasa (Minerals & Metals) ──
  { id: 33, name: "Amlasar Gandhak", sci: "Sulphur processed in Amla", category: "rasa", catLabel: "Rasa Uparasa", price: 7980, unit: "kg", moq: "5 kg", lead: "10-14 days", img: "images/amlasar-gandhak.jpg", desc: "Sulphur processed in Indian Gooseberry (Amla) juice. Used primarily for skin diseases, itching, and respiratory ailments due to its heating and purifying properties." },
